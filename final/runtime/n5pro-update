#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC1091
source /usr/local/lib/n5pro/common.sh

acquire_lock "n5pro-update.lock"
load_n5pro_config

REPO_ROOT="${REPO_ROOT:-/opt/n5pro}"
FINAL_DIR="${REPO_ROOT}/final"
RUNTIME_DIR="${FINAL_DIR}/runtime"
HOST_DIR="${FINAL_DIR}/host"
PVE_DIR="${FINAL_DIR}/pve"
PBS_DIR="${FINAL_DIR}/pbs"
LIB_SRC_DIR="${FINAL_DIR}/lib"
EXAMPLES_DIR="${FINAL_DIR}/examples"

BIN_DIR="/usr/local/bin"
LOCAL_LIB_DIR="/usr/local/lib/n5pro"

BACKUP_ROOT="/root/.n5pro-update-backups"
STAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_DIR=""
BACKUP_CREATED="false"

INSTALL_MODE="false"
CHECK_MODE="false"
SELF_CHECK_MODE="false"
DOCTOR_MODE="false"

SYNC_STATUS="NOT_RUN"
STRUCTURE_STATUS="PENDING"
SYNTAX_STATUS="PENDING"
BACKUP_STATUS="NOT_CREATED"
INSTALL_STATUS="NOT_APPLIED"
RETENTION_STATUS="NOT_RUN"

REPO_STATE="UNKNOWN"
REPO_CHANGED_COUNT="0"

SELF_CHECK_STATUS="NOT_RUN"
SELF_CHECK_OK="0"
SELF_CHECK_WARN="0"
SELF_CHECK_FAIL="0"

DOCTOR_STATUS="NOT_RUN"

RUNTIME_REQUIRED=(
  n5pro
  n5pro-post
  n5pro-update
  n5pro-doctor
)

RUNTIME_OPTIONAL=(
  n5pro-backup
  n5pro-version
  n5pro-bootstrap-pbs
  n5pro-repo-safe
  n5pro-heal
  n5pro-log
  n5pro-cron
  n5pro-ssh-setup-pbs
)

case "${1:-}" in
  --install) INSTALL_MODE="true" ;;
  --check) CHECK_MODE="true" ;;
  --self-check) SELF_CHECK_MODE="true" ;;
  --doctor) DOCTOR_MODE="true" ;;
  *)
    ;;
esac

print_header "N5Pro Update"

[[ "$EUID" -eq 0 ]] || die "Corre este script como root."
[[ -d "$REPO_ROOT" ]] || die "Repo não encontrado em ${REPO_ROOT}"
[[ -d "$FINAL_DIR" ]] || die "Diretório final não encontrado em ${FINAL_DIR}"
[[ -d "$RUNTIME_DIR" ]] || die "Diretório runtime não encontrado em ${RUNTIME_DIR}"
[[ -d "$LIB_SRC_DIR" ]] || die "Diretório lib não encontrado em ${LIB_SRC_DIR}"

mkdir -p "$LOCAL_LIB_DIR"
mkdir -p "$BIN_DIR"

backup_if_exists() {
  local f="$1"
  [[ -e "$f" || -L "$f" ]] || return 0

  if [[ "$BACKUP_CREATED" != "true" ]]; then
    BACKUP_DIR="${BACKUP_ROOT}/${STAMP}"
    mkdir -p "${BACKUP_DIR}/bin" "${BACKUP_DIR}/lib" "${BACKUP_DIR}/etc"
    BACKUP_CREATED="true"
    BACKUP_STATUS="CREATED"
  fi

  local base
  base="$(basename "$f")"

  case "$f" in
    /usr/local/bin/*)
      cp -a "$f" "${BACKUP_DIR}/bin/${base}" 2>/dev/null || true
      ;;
    /usr/local/lib/n5pro/*)
      cp -a "$f" "${BACKUP_DIR}/lib/${base}" 2>/dev/null || true
      ;;
    /etc/*)
      cp -a "$f" "${BACKUP_DIR}/etc/${base}" 2>/dev/null || true
      ;;
    *)
      cp -a "$f" "${BACKUP_DIR}/${base}" 2>/dev/null || true
      ;;
  esac
}

detect_version_file() {
  if [[ -f "${RUNTIME_DIR}/VERSION" ]]; then
    echo "${RUNTIME_DIR}/VERSION"
  elif [[ -f "${REPO_ROOT}/VERSION" ]]; then
    echo "${REPO_ROOT}/VERSION"
  elif [[ -f "${FINAL_DIR}/VERSION" ]]; then
    echo "${FINAL_DIR}/VERSION"
  else
    echo ""
  fi
}

validate_structure() {
  info "Validar estrutura do repo..."

  [[ -f "${FINAL_DIR}/bootstrap.sh" ]] || die "Falta ${FINAL_DIR}/bootstrap.sh"
  [[ -f "${LIB_SRC_DIR}/common.sh" ]] || die "Falta ${LIB_SRC_DIR}/common.sh"

  local f
  for f in "${RUNTIME_REQUIRED[@]}"; do
    [[ -f "${RUNTIME_DIR}/${f}" ]] || warn "Runtime em falta: ${RUNTIME_DIR}/${f}"
  done

  STRUCTURE_STATUS="OK"
  ok "Estrutura validada."
}

sync_git() {
  info "Sincronizar repo local..."
  cd "$REPO_ROOT"

  local changed_files=""
  changed_files="$(git status --porcelain 2>/dev/null || true)"

  if [[ -n "$changed_files" ]]; then
    REPO_STATE="DIRTY"
    REPO_CHANGED_COUNT="$(printf '%s\n' "$changed_files" | sed '/^$/d' | wc -l | tr -d ' ')"
    SYNC_STATUS="SKIPPED_LOCAL_CHANGES"
    warn "Existem alterações locais no repo. Sync git ignorado para proteger trabalho em curso."
    info "Ficheiros alterados localmente:"
    git status --short || true
    return 0
  fi

  REPO_STATE="CLEAN"
  REPO_CHANGED_COUNT="0"

  if git pull --rebase origin main; then
    SYNC_STATUS="OK"
    ok "Repo sincronizado com origin/main."
  else
    SYNC_STATUS="FAILED"
    warn "Não foi possível sincronizar via git pull --rebase origin main."
  fi
}

backup_current_state() {
  info "Criar backup dos ficheiros atuais..."

  backup_if_exists /usr/local/lib/n5pro/common.sh
  backup_if_exists /usr/local/lib/n5pro/VERSION
  backup_if_exists /etc/n5pro.conf

  local runtime_files=(
    /usr/local/bin/n5pro
    /usr/local/bin/n5pro-post
    /usr/local/bin/n5pro-update
    /usr/local/bin/n5pro-doctor
    /usr/local/bin/n5pro-backup
    /usr/local/bin/n5pro-version
    /usr/local/bin/n5pro-bootstrap-pbs
    /usr/local/bin/n5pro-repo-safe
    /usr/local/bin/n5pro-heal
    /usr/local/bin/n5pro-log
    /usr/local/bin/n5pro-cron
    /usr/local/bin/n5pro-ssh-setup-pbs
  )

  local f
  for f in "${runtime_files[@]}"; do
    backup_if_exists "$f"
  done

  ok "Backup criado."
}

prune_old_backups() {
  [[ -d "$BACKUP_ROOT" ]] || { RETENTION_STATUS="NOT_NEEDED"; return 0; }

  info "Aplicar retenção de backups (manter últimos 10)..."

  mapfile -t old_backups < <(find "$BACKUP_ROOT" -mindepth 1 -maxdepth 1 -type d | sort)

  local total="${#old_backups[@]}"
  if [[ "$total" -le 10 ]]; then
    RETENTION_STATUS="OK"
    ok "Retenção OK: ${total} backup(s) presentes."
    return 0
  fi

  local remove_count=$((total - 10))
  local i
  for ((i=0; i<remove_count; i++)); do
    rm -rf "${old_backups[$i]}"
    info "Backup removido: ${old_backups[$i]}"
  done

  RETENTION_STATUS="PRUNED"
  ok "Retenção aplicada."
}

fix_permissions_and_validate_syntax() {
  info "Validar sintaxe..."

  local files=()
  while IFS= read -r -d '' f; do
    files+=("$f")
  done < <(find "$FINAL_DIR" -type f -print0 | sort -z)

  local f base
  for f in "${files[@]}"; do
    base="$(basename "$f")"

    if [[ "$f" == *.sh || "$f" == "${RUNTIME_DIR}/"* ]]; then
      chmod +x "$f" || true
      if [[ "$base" == "VERSION" ]]; then
        ok "OK: VERSION"
      else
        bash -n "$f"
        ok "OK: ${base}"
      fi
    elif [[ "$base" == "VERSION" || "$base" == "config.env.example" ]]; then
      ok "OK: ${base}"
    fi
  done

  SYNTAX_STATUS="OK"
}

install_symlink() {
  local src="$1"
  local dst="$2"
  local label="$3"

  [[ -e "$src" ]] || {
    warn "Fonte em falta para ${label}: ${src}"
    return 0
  }

  mkdir -p "$(dirname "$dst")"
  rm -f "$dst"
  ln -s "$src" "$dst"
  ok "Ligado: ${label}"
}

install_runtime() {
  info "Instalar runtime por symlink..."

  local f
  for f in "${RUNTIME_REQUIRED[@]}" "${RUNTIME_OPTIONAL[@]}"; do
    if [[ -f "${RUNTIME_DIR}/${f}" ]]; then
      install_symlink "${RUNTIME_DIR}/${f}" "${BIN_DIR}/${f}" "${f}"
      chmod +x "${RUNTIME_DIR}/${f}" || true
    fi
  done

  install_symlink "${LIB_SRC_DIR}/common.sh" "${LOCAL_LIB_DIR}/common.sh" "common.sh"

  local version_file
  version_file="$(detect_version_file)"
  if [[ -n "$version_file" ]]; then
    install_symlink "$version_file" "${LOCAL_LIB_DIR}/VERSION" "VERSION"
  else
    warn "VERSION não encontrado no repo; versão local não foi atualizada."
  fi

  INSTALL_STATUS="APPLIED"
}

self_check_ok() {
  SELF_CHECK_OK=$((SELF_CHECK_OK + 1))
  ok "$1"
}

self_check_warn() {
  SELF_CHECK_WARN=$((SELF_CHECK_WARN + 1))
  info "$1"
}

self_check_fail() {
  SELF_CHECK_FAIL=$((SELF_CHECK_FAIL + 1))
  fail_line "$1"
}

check_runtime_item() {
  local name="$1"
  local repo_file="${RUNTIME_DIR}/${name}"
  local local_file="${BIN_DIR}/${name}"

  if [[ ! -f "$repo_file" ]]; then
    self_check_fail "Repo não contém: ${repo_file}"
    return 0
  fi

  if [[ ! -e "$local_file" && ! -L "$local_file" ]]; then
    self_check_fail "Runtime local em falta: ${local_file}"
    return 0
  fi

  if [[ -L "$local_file" ]]; then
    local target
    target="$(readlink -f "$local_file" 2>/dev/null || true)"
    local expected
    expected="$(readlink -f "$repo_file" 2>/dev/null || true)"

    if [[ -n "$target" && "$target" == "$expected" ]]; then
      self_check_ok "OK runtime symlink: ${name}"
    else
      self_check_fail "Symlink runtime aponta para destino errado: ${name}"
    fi
    return 0
  fi

  if cmp -s "$repo_file" "$local_file"; then
    self_check_ok "OK runtime: ${name}"
  else
    self_check_fail "Divergência runtime: ${name}"
  fi
}

run_self_check() {
  info "Modo --self-check ativo."
  SELF_CHECK_STATUS="RUNNING"

  echo -e "$LINE"
  echo "Self-check runtime"
  echo -e "$LINE"

  local f
  for f in "${RUNTIME_REQUIRED[@]}"; do
    check_runtime_item "$f"
  done

  for f in "${RUNTIME_OPTIONAL[@]}"; do
    if [[ ! -f "${RUNTIME_DIR}/${f}" ]]; then
      self_check_warn "Opcional não existe no repo: ${f}"
      continue
    fi

    if [[ ! -e "${BIN_DIR}/${f}" && ! -L "${BIN_DIR}/${f}" ]]; then
      self_check_warn "Opcional não instalado: ${f}"
      continue
    fi

    check_runtime_item "$f"
  done

  if [[ -f "${LIB_SRC_DIR}/common.sh" && ( -f "${LOCAL_LIB_DIR}/common.sh" || -L "${LOCAL_LIB_DIR}/common.sh" ) ]]; then
    if [[ -L "${LOCAL_LIB_DIR}/common.sh" ]]; then
      local common_target expected_common
      common_target="$(readlink -f "${LOCAL_LIB_DIR}/common.sh" 2>/dev/null || true)"
      expected_common="$(readlink -f "${LIB_SRC_DIR}/common.sh" 2>/dev/null || true)"
      if [[ -n "$common_target" && "$common_target" == "$expected_common" ]]; then
        self_check_ok "OK lib symlink: common.sh"
      else
        self_check_fail "Symlink lib aponta para destino errado: common.sh"
      fi
    elif cmp -s "${LIB_SRC_DIR}/common.sh" "${LOCAL_LIB_DIR}/common.sh"; then
      self_check_ok "OK lib: common.sh"
    else
      self_check_fail "Divergência lib: common.sh"
    fi
  else
    self_check_fail "common.sh em falta no repo ou no runtime local"
  fi

  local version_file
  version_file="$(detect_version_file)"
  if [[ -n "$version_file" && ( -f "${LOCAL_LIB_DIR}/VERSION" || -L "${LOCAL_LIB_DIR}/VERSION" ) ]]; then
    if [[ -L "${LOCAL_LIB_DIR}/VERSION" ]]; then
      local ver_target expected_ver
      ver_target="$(readlink -f "${LOCAL_LIB_DIR}/VERSION" 2>/dev/null || true)"
      expected_ver="$(readlink -f "$version_file" 2>/dev/null || true)"
      if [[ -n "$ver_target" && "$ver_target" == "$expected_ver" ]]; then
        self_check_ok "OK VERSION symlink"
      else
        self_check_fail "Symlink VERSION aponta para destino errado"
      fi
    elif cmp -s "$version_file" "${LOCAL_LIB_DIR}/VERSION"; then
      self_check_ok "OK VERSION"
    else
      self_check_fail "Divergência VERSION"
    fi
  else
    self_check_warn "VERSION ausente no repo ou no runtime local"
  fi

  if [[ "$SELF_CHECK_FAIL" -gt 0 ]]; then
    SELF_CHECK_STATUS="FAIL"
  else
    SELF_CHECK_STATUS="OK"
  fi
}

run_doctor_checks() {
  info "Modo --doctor ativo."
  DOCTOR_STATUS="RUNNING"

  run_self_check

  echo -e "$LINE"
  echo "System checks"
  echo -e "$LINE"

  if [[ -f /etc/n5pro.conf ]]; then
    ok "Config presente: /etc/n5pro.conf"
  else
    warn "Config ausente: /etc/n5pro.conf"
    DOCTOR_STATUS="WARN"
  fi

  if command -v n5pro >/dev/null 2>&1; then
    ok "Binário no PATH: n5pro"
  else
    warn "Binário ausente no PATH: n5pro"
    DOCTOR_STATUS="WARN"
  fi

  if command -v n5pro-update >/dev/null 2>&1; then
    ok "Binário no PATH: n5pro-update"
  else
    warn "Binário ausente no PATH: n5pro-update"
    DOCTOR_STATUS="WARN"
  fi

  if command -v pveversion >/dev/null 2>&1; then
    info "PVE version: $(pveversion | head -n1)"
  fi

  info "Kernel: $(uname -r)"

  local root_line mem_line
  root_line="$(df -h / | awk 'NR==2 {print $3"/"$2" usado ("$5")"}')"
  mem_line="$(free -h | awk '/^Mem:/ {print $3"/"$2" usada"}')"

  [[ -n "$root_line" ]] && info "Disco root: ${root_line}"
  [[ -n "$mem_line" ]] && info "RAM: ${mem_line}"

  if [[ "$SELF_CHECK_STATUS" == "FAIL" ]]; then
    DOCTOR_STATUS="FAIL"
  elif [[ "$DOCTOR_STATUS" != "WARN" ]]; then
    DOCTOR_STATUS="OK"
  fi
}

show_summary() {
  echo -e "$LINE"
  echo -e "${MAGENTA}${BOLD} Resumo Update${RESET}"
  echo -e "$LINE"

  echo -e "${CYAN}Repo sync  :${RESET} ${SYNC_STATUS}"
  echo -e "${CYAN}Repo local :${RESET} ${REPO_STATE}"
  echo -e "${CYAN}Alterações :${RESET} ${REPO_CHANGED_COUNT}"
  echo -e "${CYAN}Estrutura  :${RESET} ${STRUCTURE_STATUS}"
  echo -e "${CYAN}Sintaxe    :${RESET} ${SYNTAX_STATUS}"
  echo -e "${CYAN}Backup     :${RESET} ${BACKUP_STATUS}"
  echo -e "${CYAN}Instalação :${RESET} ${INSTALL_STATUS}"
  echo -e "${CYAN}Retenção   :${RESET} ${RETENTION_STATUS}"

  if [[ "$BACKUP_CREATED" == "true" ]]; then
    echo -e "${CYAN}Path backup:${RESET} ${BACKUP_DIR}"
  fi

  echo -e "$LINE"

  if [[ "$SELF_CHECK_MODE" == "true" || "$DOCTOR_MODE" == "true" ]]; then
    echo "Self-check : ${SELF_CHECK_STATUS}"
    echo "SC ok      : ${SELF_CHECK_OK}"
    echo "SC avisos  : ${SELF_CHECK_WARN}"
    echo "SC falhas  : ${SELF_CHECK_FAIL}"
  fi

  if [[ "$DOCTOR_MODE" == "true" ]]; then
    echo "Doctor     : ${DOCTOR_STATUS}"
  fi

  ok "Atualização concluída com sucesso."

  if [[ "$CHECK_MODE" == "true" ]]; then
    info "Modo --check: sem sync git, sem backup adicional, sem instalação."
  elif [[ "$SELF_CHECK_MODE" == "true" ]]; then
    info "Modo --self-check: auditoria local do runtime concluída."
  elif [[ "$DOCTOR_MODE" == "true" ]]; then
    info "Modo --doctor: diagnóstico completo concluído."
  elif [[ "$INSTALL_MODE" == "true" ]]; then
    ok "Modo --install aplicado."
  else
    warn "Para reinstalar também os links locais, usa: n5pro-update --install"
  fi

  echo -e "$LINE"
}

validate_structure

if [[ "$CHECK_MODE" == "true" ]]; then
  SYNC_STATUS="SKIPPED_CHECK_MODE"
  REPO_STATE="CHECK_ONLY"
  REPO_CHANGED_COUNT="0"
  info "Modo --check ativo."
  fix_permissions_and_validate_syntax
  show_summary
  exit 0
fi

if [[ "$SELF_CHECK_MODE" == "true" ]]; then
  SYNC_STATUS="SKIPPED_SELF_CHECK"
  SYNTAX_STATUS="SKIPPED_SELF_CHECK"
  BACKUP_STATUS="NOT_CREATED"
  INSTALL_STATUS="NOT_APPLIED"
  RETENTION_STATUS="NOT_RUN"
  run_self_check
  show_summary
  exit 0
fi

if [[ "$DOCTOR_MODE" == "true" ]]; then
  SYNC_STATUS="SKIPPED_DOCTOR"
  SYNTAX_STATUS="SKIPPED_DOCTOR"
  BACKUP_STATUS="NOT_CREATED"
  INSTALL_STATUS="NOT_APPLIED"
  RETENTION_STATUS="NOT_RUN"
  run_doctor_checks
  show_summary
  exit 0
fi

sync_git
backup_current_state
fix_permissions_and_validate_syntax

if [[ "$INSTALL_MODE" == "true" ]]; then
  install_runtime
fi

prune_old_backups
show_summary

LINE="================================================================"
CYAN="\033[38;5;14m"
MAGENTA="\033[38;5;13m"
GREEN="\033[38;5;10m"
YELLOW="\033[38;5;11m"
RED="\033[38;5;196m"
RESET="\033[0m"

detect_mode() {
  if command -v pveversion >/dev/null 2>&1; then
    echo "PVE"
  elif command -v proxmox-backup-manager >/dev/null 2>&1; then
    echo "PBS"
  else
    echo "UNKNOWN"
  fi
}

pause() {
  read -rp "Enter para continuar..." _
}

strip_ansi() {
  sed 's/\x1B\[[0-9;]*[a-zA-Z]//g'
}

center_print() {
  local text="$1"
  local clean
  local width
  local len
  local pad

  clean="$(echo -e "$text" | strip_ansi)"
  width="$(tput cols 2>/dev/null || echo 80)"
  len=${#clean}
  pad=$(( (width - len) / 2 ))
  (( pad < 0 )) && pad=0

  printf "%*s%b\n" "$pad" "" "$text"
}


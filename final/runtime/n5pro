#!/usr/bin/env bash
set -euo pipefail

COMMON_SH="/usr/local/lib/n5pro/common.sh"
CONFIG_FILE="/etc/n5pro.conf"
VERSION_FILE="/usr/local/lib/n5pro/VERSION"

[[ -f "$COMMON_SH" ]] || { echo "[ERRO] common.sh nГЈo encontrado em ${COMMON_SH}"; exit 1; }
# shellcheck disable=SC1091
source "$COMMON_SH"

load_n5pro_config || true

LINE="================================================================"
CYAN="\033[38;5;14m"
MAGENTA="\033[38;5;13m"
GREEN="\033[38;5;10m"
YELLOW="\033[38;5;11m"
RED="\033[38;5;196m"
RESET="\033[0m"

detect_mode() {
  if command -v pveversion >/dev/null 2>&1; then
    echo "PVE"
  elif command -v proxmox-backup-manager >/dev/null 2>&1; then
    echo "PBS"
  else
    echo "UNKNOWN"
  fi
}

config_exists() {
  [[ -f "$CONFIG_FILE" ]]
}

pause() {
  read -rp "Enter para continuar..." _
}

strip_ansi() {
  sed 's/\x1B\[[0-9;]*[a-zA-Z]//g'
}

center_print() {
  local text="$1"
  local clean
  local width
  local len
  local pad

  clean="$(echo -e "$text" | strip_ansi)"
  width="$(tput cols 2>/dev/null || echo 80)"
  len=${#clean}
  pad=$(( (width - len) / 2 ))
  (( pad < 0 )) && pad=0

  printf "%*s%b\n" "$pad" "" "$text"
}

get_local_version() {
  if command -v n5pro-version >/dev/null 2>&1; then
    n5pro-version local 2>/dev/null || true
    return 0
  fi

  if [[ -f "$VERSION_FILE" ]]; then
    tr -d '\n' < "$VERSION_FILE"
    return 0
  fi

  echo "unknown"
}

load_config_if_present() {
  if config_exists; then
    # shellcheck disable=SC1091
    source "$CONFIG_FILE"
  fi
}


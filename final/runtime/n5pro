    echo "2) CorreГ§ГЈo guiada"
    echo "3) Auto-correГ§ГЈo"
    echo "4) Dry-run"
    echo "5) Heal guiado"
    echo "6) Heal automГЎtico"
    echo "7) Heal + bootstrap PBS"
    echo "0) Voltar"

    read -rp "Escolha: " o
    case "$o" in
      1) n5pro-doctor ;;
      2) n5pro-doctor --fix ;;
      3) n5pro-doctor --auto ;;
      4) n5pro-doctor --fix --dry-run ;;
      5)
        has_cmd n5pro-heal && n5pro-heal || echo -e "${YELLOW}[WARN] n5pro-heal nГЈo encontrado${RESET}"
        ;;
      6)
        has_cmd n5pro-heal && n5pro-heal --auto || echo -e "${YELLOW}[WARN] n5pro-heal nГЈo encontrado${RESET}"
        ;;
      7)
        has_cmd n5pro-heal && n5pro-heal --with-bootstrap || echo -e "${YELLOW}[WARN] n5pro-heal nГЈo encontrado${RESET}"
        ;;
      0) return ;;
      *) echo -e "${YELLOW}OpГ§ГЈo invГЎlida${RESET}" ;;
    esac
    pause
  done
}

backup_menu() {
  while true; do
    clear
    echo -e "$LINE"
    echo "Backup"
    echo -e "$LINE"
    echo "1) Backup completo"
    echo "2) Backup + enviar PBS"
    echo "3) Limpar backups antigos"
    echo "0) Voltar"

    read -rp "Escolha: " o
    case "$o" in
      1)
        has_cmd n5pro-backup && confirm "Criar backup?" && n5pro-backup || echo -e "${YELLOW}[WARN] n5pro-backup nГЈo encontrado${RESET}"
        ;;
      2)
        if has_cmd n5pro-backup; then
          confirm "Backup + enviar PBS?" && n5pro-backup && echo "[TODO] upload PBS"
        else
          echo -e "${YELLOW}[WARN] n5pro-backup nГЈo encontrado${RESET}"
        fi
        ;;
      3)
        confirm "Limpar backups antigos?" && find /root/n5pro-backups -type f -name "*.tar.gz" -delete
        ;;
      0) return ;;
      *) echo -e "${YELLOW}OpГ§ГЈo invГЎlida${RESET}" ;;
    esac
    pause
  done
}


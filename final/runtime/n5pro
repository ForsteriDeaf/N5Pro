confirm() {
  read -rp "$1 [y/N]: " a
  [[ "${a,,}" =~ ^y(es)?$ ]]
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

menu_label() {
  local cmd="$1"
  local label="$2"
  if has_cmd "$cmd"; then
    echo "$label"
  else
    echo "${label} ${YELLOW}(indisponГ­vel)${RESET}"
  fi
}

show_status() {
  clear
  show_logo
  local MODE
  MODE="$(detect_mode)"

  echo

  if has_cmd pveversion || has_cmd proxmox-backup-manager; then
    echo -e "${GREEN}[OK] Ambiente Proxmox detectado${RESET}"
  else
    echo -e "${RED}[FAIL] Ambiente nГЈo suportado${RESET}"
  fi

  if config_exists; then
    echo -e "${GREEN}[OK] ConfiguraГ§ГЈo encontrada${RESET}"
  else
    echo -e "${YELLOW}[WARN] /etc/n5pro.conf em falta${RESET}"
  fi

  if has_cmd n5pro-update; then
    echo -e "${GREEN}[OK] Runtime instalado${RESET}"
  else
    echo -e "${YELLOW}[WARN] Runtime nГЈo instalado${RESET}"
  fi

  echo
  echo -e "${MAGENTA}RecomendaГ§ГЈo:${RESET}"

  if ! config_exists; then
    echo -e "рџ‘‰ Executa: ${CYAN}n5pro-post${RESET}"
  elif ! has_cmd n5pro-update; then
    echo -e "рџ‘‰ Executa: ${CYAN}n5pro-update --install${RESET}"
  else
    echo -e "${GREEN}Sistema pronto a usar вњ”${RESET}"
  fi

  echo
  echo -e "$LINE"
  echo -e "$LINE"
  echo -e "${MAGENTA} Dashboard (${MODE})${RESET}"
  echo -e "$LINE"

  load_config_if_present

  echo "[CHECK] Repo base..."
  echo "${N5PRO_REPO_BASE:-nГЈo configurado}"

  echo "[CHECK] Hostname..."
  hostname

  if [[ "$MODE" == "PVE" ]]; then
    echo "[CHECK] VersГЈo Proxmox..."
    pveversion | head -n1

    echo "[CHECK] Storages..."
    pvesm status || true

    echo "[CHECK] VMs..."
    qm list || true

    echo "[CHECK] CTs..."
    pct list || true

    echo "[CHECK] IOMMU..."
    if grep -Eiq 'iommu=pt|intel_iommu=on|amd_iommu=on' /proc/cmdline; then
      echo -e "${GREEN}[OK] IOMMU ativa${RESET}"
    else
      echo -e "${YELLOW}[WARN] IOMMU desativada${RESET}"
    fi
  elif [[ "$MODE" == "PBS" ]]; then
    echo "[CHECK] VersГЈo PBS..."
    proxmox-backup-manager version || true

    echo "[CHECK] Datastores PBS..."
    proxmox-backup-manager datastore list || true
  else
    echo -e "${YELLOW}[WARN] Ambiente nГЈo reconhecido.${RESET}"
  fi

  echo "[CHECK] Root filesystem..."
  findmnt / || true

  echo "[CHECK] Timezone..."
  timedatectl | sed -n '1,6p' || true

  local local_v remote_v
  local_v="$(get_local_version)"
  if has_cmd n5pro-version; then
    remote_v="$(n5pro-version remote 2>/dev/null || echo unknown)"
    echo "[CHECK] N5Pro version: ${local_v}"

    if [[ "$remote_v" != "unknown" && "$local_v" != "$remote_v" ]]; then
      echo -e "${YELLOW}[UPDATE] Nova versГЈo disponГ­vel: ${remote_v}${RESET}"
    else
      echo -e "${GREEN}[OK] Sistema atualizado${RESET}"
    fi
  else
    echo "[CHECK] N5Pro version: ${local_v}"
  fi

  echo -e "$LINE"
  echo -e "${GREEN}[OK] Estado visual completo!${RESET}"
  echo -e "$LINE"
}

update_menu() {
  while true; do
    clear
    echo -e "$LINE"
    echo "Update"
    echo -e "$LINE"
    echo "1) Ver versГЈo atual"
    echo "2) Verificar updates"
    echo "3) Atualizar repo"
    echo "4) Atualizar + instalar"
    echo "0) Voltar"

    read -rp "Escolha: " o
    case "$o" in
      1)
        if has_cmd n5pro-version; then
          n5pro-version local
        else
          echo "$(get_local_version)"
        fi
        ;;
      2)
        if has_cmd n5pro-version; then
          n5pro-version check
        else
          echo -e "${YELLOW}[WARN] n5pro-version nГЈo encontrado${RESET}"
        fi
        ;;
      3)
        n5pro-update
        ;;
      4)
        n5pro-update --install
        ;;
      0)
        return
        ;;
      *)
        echo -e "${YELLOW}OpГ§ГЈo invГЎlida${RESET}"
        ;;
    esac
    pause
  done
}

doctor_menu() {
  while true; do

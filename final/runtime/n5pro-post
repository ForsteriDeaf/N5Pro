#!/usr/bin/env bash
set -e

[[ -f /etc/n5pro.conf ]] || { echo "[ERRO] /etc/n5pro.conf não encontrado"; exit 1; }
# shellcheck disable=SC1091
source /etc/n5pro.conf

LINE="==========================================================="
DRY_RUN="false"

SCRIPT_HOST_POSTINSTALL="host/01-PVE-Host-PostInstall.sh"
SCRIPT_CREATE_PBS_VM="pve/02-PVE-CreatePBSVM.sh"
SCRIPT_CREATE_UNRAID_VM="pve/03-PVE-CreateUnraidVM.sh"
SCRIPT_ADD_PBS_STORAGE="pve/04-PVE-AddPBSStorage.sh"
SCRIPT_CREATE_BACKUP_JOB="pve/05-PVE-CreatePBSBackupJob.sh"
SCRIPT_PBS_POSTINSTALL="pbs/06-PBS-PostInstall.sh"

repo_check() {
  [[ -n "${N5PRO_REPO_BASE:-}" ]]
}

run_remote() {
  local script_path="$1"

  repo_check || {
    echo "[ERRO] N5PRO_REPO_BASE não definido corretamente em /etc/n5pro.conf"
    exit 1
  }

  if [[ "$DRY_RUN" == "true" ]]; then
    echo "[DRY-RUN] bash <(curl -fsSL \"${N5PRO_REPO_BASE}/${script_path}\")"
  else
    bash <(curl -fsSL "${N5PRO_REPO_BASE}/${script_path}")
  fi
}

detect_mode() {
  if command -v pveversion >/dev/null 2>&1; then
    echo "PVE"
  elif command -v proxmox-backup-manager >/dev/null 2>&1; then
    echo "PBS"
  else
    echo "UNKNOWN"
  fi
}

pause() {
  read -rp "Enter para continuar..." _
}

show_header() {
  clear
  echo "$LINE"
  echo " N5Pro Post PRO v1.0"
  echo "$LINE"
  echo "Host      : $(hostname)"
  echo "Modo      : $(detect_mode)"
  echo "Repo base : ${N5PRO_REPO_BASE}"
  echo "Dry-run   : ${DRY_RUN}"
  echo "$LINE"
}

show_status() {
  if command -v n5pro >/dev/null 2>&1; then
    n5pro
  else
    echo "[WARN] n5pro não encontrado."
  fi
  pause
}

wizard_pve_core() {
  clear
  echo "$LINE"
  echo " N5Pro Wizard - PVE / Core"
  echo "$LINE"
  echo "Este modo faz:"
  echo " 1) Validar ISO PBS"
  echo " 2) Criar PBS VM"
  echo " 3) Criar Unraid VM"
  echo "$LINE"

  local iso_found=""
  if command -v pvesm >/dev/null 2>&1; then
    iso_found="$(pvesm list local 2>/dev/null | awk 'NR>1 {print $1}' | grep -i 'proxmox-backup-server.*\.iso\|pbs.*\.iso' | head -n1 || true)"
  fi

  if [[ -n "$iso_found" ]]; then
    echo "[OK] ISO PBS encontrado em local:iso -> ${iso_found}"
  else
    echo "[WARN] ISO PBS não encontrado em local:iso"
    echo "Coloca o ISO em: Datacenter -> pve -> local -> ISO Images"
    echo
    read -rp "Continuar mesmo assim? [y/N]: " ans_iso
    [[ "${ans_iso,,}" =~ ^y(es)?$ ]] || return 0
  fi

  echo
  read -rp "Queres continuar? [y/N]: " ans
  [[ "${ans,,}" =~ ^y(es)?$ ]] || return 0

  run_remote "$SCRIPT_CREATE_PBS_VM"
  run_remote "$SCRIPT_CREATE_UNRAID_VM"

  echo
  echo "$LINE"
  echo " Próximos passos"
  echo "$LINE"
  echo " - Instalar/arrancar o Unraid"
  echo " - Entrar na PBS e correr: n5pro-post"
  echo "$LINE"
  pause
}

wizard_pve_finalize() {
  clear
  echo "$LINE"
  echo " N5Pro Wizard - PVE / Finalize"
  echo "$LINE"
  echo "Este modo faz:"
  echo " 1) Adicionar storage PBS"
  echo " 2) Criar backup jobs PBS"
  echo "$LINE"
  read -rp "Queres continuar? [y/N]: " ans
  [[ "${ans,,}" =~ ^y(es)?$ ]] || return 0

  run_remote "$SCRIPT_ADD_PBS_STORAGE"
  run_remote "$SCRIPT_CREATE_BACKUP_JOB"
  pause
}

wizard_pbs_core() {
  clear
  echo "$LINE"
  echo " N5Pro Wizard - PBS"
  echo "$LINE"
  echo "Este modo faz:"
  echo " 1) Preparar PBS"
  echo "$LINE"
  read -rp "Queres continuar? [y/N]: " ans
  [[ "${ans,,}" =~ ^y(es)?$ ]] || return 0

  run_remote "$SCRIPT_PBS_POSTINSTALL"
  pause
}

run_host_postinstall() {
  clear
  echo "$LINE"
  echo " N5Pro Wizard - Host Base"
  echo "$LINE"
  echo "Este modo faz o post-install base do host PVE."
  echo "$LINE"
  read -rp "Queres continuar? [y/N]: " ans
  [[ "${ans,,}" =~ ^y(es)?$ ]] || return 0

  run_remote "$SCRIPT_HOST_POSTINSTALL"
  pause
}

toggle_dry_run() {
  [[ "$DRY_RUN" == "true" ]] && DRY_RUN="false" || DRY_RUN="true"
}

while true; do
  MODE="$(detect_mode)"
  show_header

  case "$MODE" in
    PVE)
      echo "1) Estado do host"
      echo "2) Preparar host base (post-install)"
      echo "3) Wizard: criar PBS VM + Unraid VM"
      echo "4) Wizard: integrar PBS + criar jobs"
      echo "5) Manual: criar PBS VM"
      echo "6) Manual: criar Unraid VM"
      echo "7) Manual: adicionar storage PBS"
      echo "8) Manual: criar backup jobs PBS"
      echo "9) Mostrar /etc/n5pro.conf"
      echo "10) Alternar dry-run"
      echo "0) Sair"
      read -rp "Escolha: " opt

      case "$opt" in
        1) show_status ;;
        2) run_host_postinstall ;;
        3) wizard_pve_core ;;
        4) wizard_pve_finalize ;;
        5) run_remote "$SCRIPT_CREATE_PBS_VM"; pause ;;
        6) run_remote "$SCRIPT_CREATE_UNRAID_VM"; pause ;;
        7) run_remote "$SCRIPT_ADD_PBS_STORAGE"; pause ;;
        8) run_remote "$SCRIPT_CREATE_BACKUP_JOB"; pause ;;
        9) cat /etc/n5pro.conf; pause ;;
        10) toggle_dry_run ;;
        0) exit 0 ;;
      esac
      ;;
    PBS)
      echo "1) Alternar dry-run"
      echo "2) Preparar PBS (post-install)"
      echo "3) Mostrar datastores PBS"
      echo "4) Mostrar /etc/n5pro.conf"
      echo "0) Sair"
      read -rp "Escolha: " opt

      case "$opt" in
        1) toggle_dry_run ;;
        2) wizard_pbs_core ;;
        3) proxmox-backup-manager datastore list || true; pause ;;
        4) cat /etc/n5pro.conf; pause ;;
        0) exit 0 ;;
      esac
      ;;
    *)
      echo "Ambiente não reconhecido."
      exit 1
      ;;
  esac
done
